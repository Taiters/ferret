{
  "name": "@taiters/ferret",
  "version": "0.2.0",
  "author": "Dan Tait <dantait91@gmail.com> (https://dotslashdan.com)",
  "description": "Semantic codebase search for LLMs — index once, query every conversation",
  "keywords": [
    "semantic-search",
    "code-search",
    "codebase-search",
    "vector-search",
    "embeddings",
    "llm",
    "ai",
    "claude",
    "claude-code",
    "mcp",
    "rag",
    "tree-sitter",
    "lancedb",
    "developer-tools",
    "cli"
  ],
  "license": "MIT",
  "homepage": "https://github.com/Taiters/ferret#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Taiters/ferret.git"
  },
  "bugs": {
    "url": "https://github.com/Taiters/ferret/issues"
  },
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "skills/",
    "bin/",
    "LICENCE",
    "README.md"
  ],
  "type": "module",
  "bin": {
    "ferret": "dist/ferret.js"
  },
  "exports": {
    ".": "./dist/ferret.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "version": "node scripts/sync-version.mjs && git add .claude-plugin/plugin.json src/ferret.ts",
    "index": "node dist/ferret.js index",
    "search": "node dist/ferret.js search",
    "stats": "node dist/ferret.js stats",
    "bench": "npx tsx scripts/benchmark.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@huggingface/transformers": "^4.1.0",
    "@lancedb/lancedb": "^0.14.0",
    "apache-arrow": ">=13.0.0 <=17.0.0",
    "commander": "^12.1.0",
    "glob": "^11.0.0",
    "tree-sitter": "^0.21.1",
    "tree-sitter-javascript": "^0.21.4",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-typescript": "^0.21.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^1.6.0"
  }
}
